# ── Required ─────────────────────────────────────────────────────────────────

# Postgres connection string. Anything `pg` understands works.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Password for the login page (alias: APP_PASSWORD).
DASHBOARD_PASSWORD=change-me

# ── Recommended (auto-generate with: openssl rand -hex 32) ───────────────────

# Bearer token required by /api/cron/* endpoints. Also acts as the fallback
# secret for both session cookies and upload-URL signing if the dedicated keys
# below are unset — fine for a quick start, but rotate independently in prod.
CRON_SECRET=

# 32-byte hex secret signing the `app_session` cookie. Falls back to CRON_SECRET.
SESSION_SECRET=

# 32-byte hex secret signing short-lived PUT upload URLs. Falls back to CRON_SECRET.
UPLOAD_SIGN_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Where uploaded files live. /data/uploads inside the Docker image (mount a
# volume there in production); for local dev, point this at a writable folder.
UPLOADS_DIR=/data/uploads

# Absolute origin used to build full URLs (e.g. signed upload URLs). Leave
# empty in dev — relative paths work fine.
NEXT_PUBLIC_BASE_URL=

# ── Integrations (all optional — features degrade gracefully if unset) ───────

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
METRICOOL_API_TOKEN=
METRICOOL_USER_ID=
METRICOOL_BLOG_ID=
SCRAPECREATORS_API_KEY=
TAVILY_API_KEY=
